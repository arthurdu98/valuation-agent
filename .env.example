# =============================================================================
# Valuation Monitor - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# =============================================================================

# --- Database ---
# PostgreSQL connection URL
DB_URL=postgresql://valuation:valuation_dev@localhost:5432/valuation

# --- LLM API Keys ---
# Anthropic Claude API key
CLAUDE_API_KEY=

# DeepSeek API key
DEEPSEEK_API_KEY=

# Alibaba Qwen API key
QWEN_API_KEY=

# OpenAI API key
OPENAI_API_KEY=

# --- Data Source Credentials ---
# Tushare Pro token for A-share market data
TUSHARE_TOKEN=

# FRED (Federal Reserve Economic Data) API key
FRED_API_KEY=

# --- Data Source Toggles ---
# Enable AKShare data source (true/false)
AKSHARE_ENABLED=true

# --- Paths ---
# Path to LLM configuration YAML file
LLM_CONFIG_PATH=configs/llm.yaml

# --- Scheduling ---
# Interval in hours between data collection runs
DATA_COLLECTION_INTERVAL_HOURS=6

# --- Development ---
# Enable debug mode (true/false)
DEBUG=false
